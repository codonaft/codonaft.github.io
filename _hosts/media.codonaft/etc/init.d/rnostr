#!/sbin/openrc-run

rc_app="${RC_SVCNAME%%.*}"

case "${RC_SVCNAME}" in
	*.*)
		rc_user="${rc_app}-${RC_SVCNAME#*.}"
		;;
	*)
		rc_user="${rc_app}"
		;;
esac

command="/usr/local/bin/${rc_app}"
command_user="${rc_user}:${rc_user}"
command_background="true"
command_args="relay -c /etc/${rc_app}/${RC_SVCNAME}.toml"
retry="60"

pidfile="/run/${RC_SVCNAME}.pid"
output_logger="logger -t ${RC_SVCNAME}"
error_logger="logger -t ${RC_SVCNAME}"

depend() {
	need net
	use logger
}

start_pre() {
	home_dir=$(getent passwd ${rc_user} | cut -d: -f6)
	mkdir -p "${home_dir}"
	chmod 00700 "${home_dir}"
	chown "${rc_user}:${rc_user}" "${home_dir}"
}
