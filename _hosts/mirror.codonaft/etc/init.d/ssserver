#!/sbin/openrc-run

command="/usr/local/bin/${RC_SVCNAME}"
command_user="nobody:nobody"
command_background="true"
command_args="${shadowsocks_args}"

capabilities="^cap_net_admin,^cap_net_bind_service"
pidfile="/run/${RC_SVCNAME}.pid"
output_logger="logger -t ${RC_SVCNAME}"
error_logger="logger -t ${RC_SVCNAME}"

rc_ulimit="-n 65536"

depend() {
	need net
	use logger
}
